# ══════════════════════════════════════════════════════════════
#  En el servidor exporta estas variables antes de correr Docker
#  NO crees un archivo .env — usa variables del sistema:
#
#  Linux/Mac:
#    export AWS_ACCESS_KEY_ID=tu_clave
#    export AWS_SECRET_ACCESS_KEY=tu_secret
#    export API_ASISTENCIA_URL=http://172.20.4.59:1000/api/cargar-asistencia/
#    docker compose up -d
#
#  Windows (PowerShell):
#    $env:AWS_ACCESS_KEY_ID="tu_clave"
#    $env:AWS_SECRET_ACCESS_KEY="tu_secret"
#    $env:API_ASISTENCIA_URL="http://172.20.4.69:8000/api/cargar-asistencia/"
#    docker compose up -d
# ══════════════════════════════════════════════════════════════

API_ASISTENCIA_URL=http://172.20.4.59:1000/api/cargar-asistencia/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
DYNAMODB_TABLE=Marcaciones
INTERVALO_MINUTOS=15
